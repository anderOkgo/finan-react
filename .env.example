# Local copy of the real credentials that otherwise live only in this
# project's private Google Drive folder. Copy this file to `.env` and
# fill in real values -- `.env` is gitignored and never committed.
#
# Same migration as auth-data/finan-data/animecream-data/module-data/
# animecream-react -- see auth-data's (archived) docs/credential-
# migration-runbook.md for the full story.
#
# Variable names intentionally keep the old "keys/<name>.txt" suffix,
# so com/db-sync-FTP-both.bat keeps working unchanged -- only where
# the values are read from changes.

FTPUsername.txt=
FTPPss.txt=
FTPserver.txt=
FTPFolder.txt=
LocalPath.txt=
